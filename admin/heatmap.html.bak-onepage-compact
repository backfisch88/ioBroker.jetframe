<!doctype html>
<html lang="de">
<head>
	<meta charset="utf-8" />
	<meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
	<title>JetFrame Heatmap</title>
	<style>
		:root {
			--bg: #05060a;
			--muted: rgba(255,255,255,.62);
			--green: #35e66b;
			--blue: #56a8ff;
			--yellow: #ffd84d;
			--red: #ff5a5a;
		}

		* {
			box-sizing: border-box;
			-webkit-tap-highlight-color: transparent;
		}

		html, body {
			margin: 0;
			width: 100%;
			min-height: 100dvh;
			background: var(--bg);
			color: white;
			font-family: -apple-system, BlinkMacSystemFont, "SF Pro Display", "Helvetica Neue", Arial, sans-serif;
			overflow: hidden;
		}

		body {
			background:
				radial-gradient(circle at 16% 8%, rgba(70,110,180,.34), transparent 38%),
				radial-gradient(circle at 88% 22%, rgba(255,150,60,.16), transparent 34%),
				linear-gradient(145deg, #090b11, #020306 72%);
		}

		#app {
			width: 100vw;
			height: 100dvh;
			padding: calc(10px + env(safe-area-inset-top)) 12px calc(10px + env(safe-area-inset-bottom));
			display: flex;
			justify-content: center;
			align-items: center;
		}

		.card {
			width: min(820px, 96vw);
			height: min(1080px, 94dvh);
			border-radius: 36px;
			padding: 22px;
			background: linear-gradient(145deg, rgba(62,70,90,.56), rgba(18,18,20,.78));
			border: 1px solid rgba(255,255,255,.18);
			box-shadow:
				0 35px 100px rgba(0,0,0,.58),
				inset 0 1px 0 rgba(255,255,255,.22);
			backdrop-filter: blur(24px);
			-webkit-backdrop-filter: blur(24px);
			overflow: hidden;
			position: relative;
		}

		.header {
			display: flex;
			justify-content: space-between;
			align-items: flex-start;
			gap: 12px;
			margin-bottom: 10px;
		}

		.title {
			font-size: clamp(22px, 5.2vw, 34px);
			font-weight: 900;
			letter-spacing: -.055em;
			line-height: .95;
		}

		.sub {
			margin-top: 6px;
			color: var(--muted);
			font-size: 14px;
			font-weight: 650;
		}

		.livePill {
			flex: 0 0 auto;
			padding: 7px 12px;
			border-radius: 999px;
			background: rgba(53,230,107,.13);
			border: 1px solid rgba(53,230,107,.28);
			color: rgba(210,255,225,.92);
			font-size: 12px;
			font-weight: 850;
			white-space: nowrap;
		}

		.stats {
			display: grid;
			grid-template-columns: repeat(4, 1fr);
			gap: 8px;
			margin-bottom: 10px;
		}

		.stat {
			min-height: 58px;
			border-radius: 18px;
			background: rgba(255,255,255,.075);
			border: 1px solid rgba(255,255,255,.12);
			display: flex;
			flex-direction: column;
			align-items: center;
			justify-content: center;
		}

		.value {
			font-size: clamp(22px, 6vw, 34px);
			font-weight: 900;
			letter-spacing: -.04em;
		}

		.label {
			margin-top: 3px;
			font-size: 8px;
			letter-spacing: .13em;
			color: var(--muted);
			font-weight: 800;
		}

		.rush {
			min-height: 42px;
			border-radius: 18px;
			padding: 8px 12px;
			margin-bottom: 10px;
			background: rgba(255,216,77,.10);
			border: 1px solid rgba(255,216,77,.20);
			color: rgba(255,240,170,.94);
			font-size: clamp(11px, 2.9vw, 14px);
			font-weight: 800;
			display: flex;
			align-items: center;
			justify-content: space-between;
			gap: 10px;
		}

		.rush.hot {
			background: rgba(255,90,90,.13);
			border-color: rgba(255,90,90,.28);
			color: #ffd6d6;
			box-shadow: 0 0 28px rgba(255,90,90,.12);
		}

		.scroller {
			display: flex;
			gap: 10px;
			overflow-x: auto;
			scroll-snap-type: x mandatory;
			padding: 2px 2px 14px;
			margin: 0 -2px;
			-webkit-overflow-scrolling: touch;
		}

		.scroller::-webkit-scrollbar {
			display: none;
		}

		.hourCard {
			scroll-snap-align: center;
			flex: 0 0 min(190px, 60vw);
			min-height: 158px;
			border-radius: 26px;
			padding: 16px;
			background: rgba(255,255,255,.075);
			border: 1px solid rgba(255,255,255,.12);
			position: relative;
			overflow: hidden;
		}

		.hourCard::before {
			content: "";
			position: absolute;
			inset: 0;
			opacity: var(--heat, .08);
			background:
				radial-gradient(circle at 50% 0%, rgba(53,230,107,.9), transparent 62%),
				linear-gradient(145deg, rgba(86,168,255,.7), rgba(255,216,77,.6));
			pointer-events: none;
		}

		.hourCard.now {
			border-color: rgba(53,230,107,.4);
			box-shadow: 0 0 28px rgba(53,230,107,.16);
		}

		.hourCard.best {
			border-color: rgba(255,216,77,.42);
			box-shadow: 0 0 28px rgba(255,216,77,.16);
		}

		.hourInner {
			position: relative;
			z-index: 2;
		}

		.hourTop {
			display: flex;
			justify-content: space-between;
			align-items: center;
			margin-bottom: 10px;
		}

		.hour {
			font-size: 24px;
			font-weight: 950;
			letter-spacing: -.055em;
		}

		.badge {
			padding: 5px 8px;
			border-radius: 999px;
			background: rgba(0,0,0,.22);
			border: 1px solid rgba(255,255,255,.13);
			color: rgba(255,255,255,.78);
			font-size: 11px;
			font-weight: 850;
		}

		.hourTotal {
			font-size: 46px;
			line-height: .9;
			font-weight: 950;
			letter-spacing: -.075em;
		}

		.hourSub {
			margin-top: 8px;
			color: var(--muted);
			font-size: 12px;
			font-weight: 750;
		}

		.bars {
			display: grid;
			grid-template-columns: repeat(3, 1fr);
			gap: 6px;
			margin-top: 12px;
		}

		.bar {
			height: 38px;
			border-radius: 13px;
			background: rgba(255,255,255,.09);
			border: 1px solid rgba(255,255,255,.10);
			display: flex;
			align-items: center;
			justify-content: center;
			font-weight: 900;
			font-size: 12px;
		}

		.rankings {
			display: grid;
			grid-template-columns: 1fr 1fr;
			gap: 10px;
			margin-top: 4px;
		}

		.panel {
			border-radius: 22px;
			background: rgba(255,255,255,.07);
			border: 1px solid rgba(255,255,255,.11);
			padding: 13px;
			min-height: 132px;
			overflow: hidden;
		}

		.panel h3 {
			margin: 0 0 8px;
			font-size: 13px;
			letter-spacing: .08em;
			color: var(--muted);
			text-transform: uppercase;
		}

		.panel pre {
			margin: 0;
			white-space: pre-wrap;
			font-family: inherit;
			font-size: 13px;
			line-height: 1.35;
			font-weight: 750;
			color: rgba(255,255,255,.88);
		}

		.footer {
			color: rgba(255,255,255,.42);
			font-size: 11px;
			font-weight: 700;
			text-align: center;
			margin-top: 10px;
			padding-bottom: 4px;
		}

		@media (max-width: 540px) {
			.card {
				padding: 14px;
				border-radius: 28px;
			}

			.stats {
				grid-template-columns: repeat(2, 1fr);
			}

			.rankings {
				grid-template-columns: 1fr 1fr;
			}

			.panel {
				padding: 11px;
				min-height: 106px;
				max-height: 142px;
			}

			.panel h3 {
				font-size: 11px;
				margin-bottom: 6px;
			}

			.panel pre {
				font-size: 11px;
				line-height: 1.28;
			}

			.footer {
				display: none;
			}
		}
	</style>
</head>
<body>
	<div id="app">
		<div class="card">
			<div class="header">
				<div>
					<div class="title">✈️ JetFrame<br>Heatmap</div>
					<div id="dateText" class="sub">Heute</div>
				</div>
				<div id="livePill" class="livePill">LIVE</div>
			</div>

			<div class="stats">
				<div class="stat">
					<div id="totalFlights" class="value">–</div>
					<div class="label">FLÜGE</div>
				</div>
				<div class="stat">
					<div id="landings" class="value">–</div>
					<div class="label">LANDUNGEN</div>
				</div>
				<div class="stat">
					<div id="departures" class="value">–</div>
					<div class="label">STARTS</div>
				</div>
				<div class="stat">
					<div id="overflights" class="value">–</div>
					<div class="label">ÜBERFLÜGE</div>
				</div>
			</div>

			<div id="rushBox" class="rush">
				<span id="rushText">Lade Traffic…</span>
				<span id="bestText">Beste Zeit: –</span>
			</div>

			<div id="hourScroller" class="scroller"></div>

			<div class="rankings">
				<div class="panel">
					<h3>Top Airlines</h3>
					<pre id="airlineRanking">–</pre>
				</div>
				<div class="panel">
					<h3>Top Routen</h3>
					<pre id="routeRanking">–</pre>
				</div>
			</div>

			<div id="footer" class="footer">Auto-Refresh alle 10 Sekunden</div>
		</div>
	</div>

	<script>
		let API_BASE = (() => {
			const proto = window.location.protocol || 'http:';
			const host = window.location.hostname || '127.0.0.1';
			const url = new URL(window.location.href);
			const apiHost = url.searchParams.get('apiHost') || host;
			const apiPort = url.searchParams.get('apiPort') || '8087';
			return proto + '//' + apiHost + ':' + apiPort;
		})();

		const DP_ROOT = (() => {
			const url = new URL(window.location.href);
			const instance = url.searchParams.get('instance') || '0';
			return 'jetframe.' + String(instance).replace(/[^0-9]/g, '');
		})();

		const BASE = DP_ROOT + '.statistics.today';

		const IDS = {
			date: BASE + '.date',
			totalFlights: BASE + '.totalFlights',
			landings: BASE + '.landings',
			departures: BASE + '.departures',
			overflights: BASE + '.overflights',
			hourly: BASE + '.hourly',
			bestSpotterHour: BASE + '.bestSpotterHour',
			currentHourFlights: BASE + '.currentHourFlights',
			rushHourNow: BASE + '.rushHourNow',
			rushHourText: BASE + '.rushHourText',
			airlineRankingText: BASE + '.airlineRankingText',
			routeRankingText: BASE + '.routeRankingText',
		};

		function $(id) {
			return document.getElementById(id);
		}

		function clean(v) {
			if (v === null || v === undefined) return '';
			v = String(v).trim();
			if (v === 'null' || v === 'undefined') return '';
			if ((v.startsWith('"') && v.endsWith('"')) || (v.startsWith("'") && v.endsWith("'"))) {
				v = v.slice(1, -1);
			}
			return v.replace(/\\"/g, '"').replace(/\\n/g, '\n').trim();
		}

		async function readState(id) {
			try {
				const res = await fetch(API_BASE + '/getPlainValue/' + encodeURIComponent(id), {
					cache: 'no-store',
				});
				if (!res.ok) return '';
				return clean(await res.text());
			} catch {
				return '';
			}
		}

		async function readAll() {
			const entries = await Promise.all(
				Object.entries(IDS).map(async ([k, id]) => [k, await readState(id)]),
			);
			return Object.fromEntries(entries);
		}

		function num(v) {
			const n = Number(String(v).replace(',', '.'));
			return Number.isFinite(n) ? n : 0;
		}

		function parseHourly(raw) {
			try {
				const data = JSON.parse(raw || '{}');
				const result = {};

				for (let h = 0; h < 24; h++) {
					const key = String(h).padStart(2, '0');
					const v = data[key] || {};
					result[key] = {
						total: Number(v.total || 0),
						landings: Number(v.landings || 0),
						departures: Number(v.departures || 0),
						overflights: Number(v.overflights || 0),
					};
				}

				return result;
			} catch {
				const result = {};
				for (let h = 0; h < 24; h++) {
					result[String(h).padStart(2, '0')] = { total: 0, landings: 0, departures: 0, overflights: 0 };
				}
				return result;
			}
		}

		function renderHours(hourly) {
			const scroller = $('hourScroller');
			const nowHour = String(new Date().getHours()).padStart(2, '0');
			const max = Math.max(1, ...Object.values(hourly).map(v => v.total));
			const bestHour = Object.entries(hourly).sort((a, b) => b[1].total - a[1].total)[0]?.[0] || '';

			scroller.innerHTML = '';

			for (let h = 0; h < 24; h++) {
				const key = String(h).padStart(2, '0');
				const v = hourly[key] || { total: 0, landings: 0, departures: 0, overflights: 0 };
				const heat = Math.min(0.72, Math.max(0.06, v.total / max * 0.72));

				const card = document.createElement('div');
				card.className = 'hourCard';
				if (key === nowHour) card.classList.add('now');
				if (key === bestHour && v.total > 0) card.classList.add('best');
				card.style.setProperty('--heat', heat.toFixed(2));

				card.innerHTML = `
					<div class="hourInner">
						<div class="hourTop">
							<div class="hour">${key}:00</div>
							<div class="badge">${key === nowHour ? 'JETZT' : key === bestHour && v.total > 0 ? 'PEAK' : 'HOUR'}</div>
						</div>
						<div class="hourTotal">${v.total}</div>
						<div class="hourSub">Flugbewegungen</div>
						<div class="bars">
							<div class="bar">🛬 ${v.landings}</div>
							<div class="bar">🛫 ${v.departures}</div>
							<div class="bar">🛩️ ${v.overflights}</div>
						</div>
					</div>
				`;

				scroller.appendChild(card);
			}

			setTimeout(() => {
				const now = scroller.querySelector('.hourCard.now');
				if (now) now.scrollIntoView({ behavior: 'smooth', inline: 'center', block: 'nearest' });
			}, 200);
		}

		function render(data) {
			$('dateText').textContent = data.date ? 'Heute · ' + data.date : 'Heute';
			$('totalFlights').textContent = num(data.totalFlights);
			$('landings').textContent = num(data.landings);
			$('departures').textContent = num(data.departures);
			$('overflights').textContent = num(data.overflights);

			const rush = clean(data.rushHourNow) === 'true';
			$('rushBox').classList.toggle('hot', rush);
			$('rushText').textContent = clean(data.rushHourText) || 'Noch keine Rushhour erkannt';
			$('bestText').textContent = clean(data.bestSpotterHour) ? 'Beste Zeit: ' + clean(data.bestSpotterHour) : 'Beste Zeit: –';

			$('airlineRanking').textContent = clean(data.airlineRankingText) || '–';
			$('routeRanking').textContent = clean(data.routeRankingText) || '–';

			renderHours(parseHourly(data.hourly));
		}

		async function poll() {
			const data = await readAll();
			render(data);
		}

		poll();
		setInterval(poll, 10000);
	</script>
</body>
</html>
