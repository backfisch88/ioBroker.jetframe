		<title>JetFrame</title>

<link rel="manifest" href="manifest.webmanifest">
<link rel="apple-touch-icon" href="jetframe.png">
<link rel="icon" type="image/png" href="jetframe.png">
<meta name="apple-mobile-web-app-capable" content="yes">
<meta name="mobile-web-app-capable" content="yes">
<meta name="apple-mobile-web-app-status-bar-style" content="black-translucent">
<meta name="theme-color" content="#05060a">


		<style>
			:root {
				--bg: #05060a;
				--muted: rgba(255, 255, 255, 0.62);
				--yellow: #ffd84d;
				--green: #35e66b;
				--blue: #56a8ff;
			}

			* {
				box-sizing: border-box;
				-webkit-tap-highlight-color: transparent;
			}

			html,
			body {
				margin: 0;
				width: 100%;
				height: 100%;
				min-height: 100dvh;
				overflow: hidden;
				background: var(--bg);
				color: #fff;
				font-family: -apple-system, BlinkMacSystemFont, 'SF Pro Display', 'Helvetica Neue', Arial, sans-serif;
			}

			body {
				background:
					radial-gradient(circle at 15% 8%, rgba(70, 110, 180, 0.32), transparent 38%),
					radial-gradient(circle at 86% 22%, rgba(255, 150, 60, 0.16), transparent 34%),
					linear-gradient(145deg, #090b11, #020306 72%);
			}

			#app {
				position: relative;
				width: 100vw;
				height: 100dvh;
				padding: calc(14px + env(safe-area-inset-top)) 14px calc(14px + env(safe-area-inset-bottom)) 14px;
				display: flex;
				justify-content: center;
				align-items: center;
			}

			.wall {
				width: min(760px, 94vw);
				height: min(1180px, 92dvh);
				max-height: calc(100dvh - env(safe-area-inset-top) - env(safe-area-inset-bottom) - 16px);
				border-radius: 40px;
				padding: 26px;
				background: linear-gradient(145deg, rgba(62, 70, 90, 0.56), rgba(18, 18, 20, 0.78));
				border: 1px solid rgba(255, 255, 255, 0.18);
				box-shadow:
					0 35px 100px rgba(0, 0, 0, 0.58),
					inset 0 1px 0 rgba(255, 255, 255, 0.22);
				backdrop-filter: blur(24px);
				-webkit-backdrop-filter: blur(24px);
				overflow: hidden;
				position: relative;
			}

			.header {
				display: flex;
				justify-content: space-between;
				align-items: center;
				gap: 10px;
				color: var(--muted);
				font-size: clamp(17px, 4.6vw, 24px);
				margin-bottom: 16px;
			}

			.title {
				flex: 1 1 auto;
				min-width: 0;
				overflow: hidden;
				white-space: nowrap;
				text-overflow: ellipsis;
			}

			.live {
				display: flex;
				align-items: center;
				gap: 10px;
				white-space: nowrap;
			}

			.toggleBtn {
				border: 1px solid rgba(255, 255, 255, 0.16);
				background: rgba(255, 255, 255, 0.08);
				color: rgba(255, 255, 255, 0.62);
				border-radius: 999px;
				padding: 7px 14px;
				font-size: 14px;
				font-weight: 800;
				letter-spacing: 0.08em;
				line-height: 1;
			}

			.toggleBtn.on {
				background: rgba(53, 230, 107, 0.16);
				color: #35e66b;
				border-color: rgba(53, 230, 107, 0.35);
				box-shadow: 0 0 16px rgba(53, 230, 107, 0.22);
			}

			.speechBtn.on {
				background: rgba(86, 168, 255, 0.16);
				color: #8fc5ff;
				border-color: rgba(86, 168, 255, 0.36);
				box-shadow: 0 0 16px rgba(86, 168, 255, 0.22);
			}

			.dot {
				width: 12px;
				height: 12px;
				border-radius: 50%;
				background: var(--green);
				box-shadow: 0 0 16px rgba(53, 230, 107, 0.85);
			}

			.empty .dot {
				background: #777;
				box-shadow: none;
			}

			.photoWrap {
				position: relative;
				width: 100%;
				height: 34%;
				min-height: 210px;
				border-radius: 30px;
				overflow: hidden;
				background: rgba(255, 255, 255, 0.055);
				border: 1px solid rgba(255, 255, 255, 0.13);
			}

			.photoWrap img {
				width: 100%;
				height: 100%;
				object-fit: cover;
			}

			.placeholder {
				width: 100%;
				height: 100%;
				display: grid;
				place-items: center;
				position: relative;
				overflow: hidden;
				background:
					radial-gradient(circle at 50% 50%, rgba(53, 230, 107, 0.1), transparent 42%),
					linear-gradient(145deg, rgba(255, 255, 255, 0.07), rgba(255, 255, 255, 0.02));
			}

			.radarCircle {
				position: absolute;
				width: 56%;
				aspect-ratio: 1;
				border-radius: 50%;
				border: 1px solid rgba(53, 230, 107, 0.22);
				box-shadow:
					0 0 0 34px rgba(53, 230, 107, 0.035),
					0 0 0 70px rgba(53, 230, 107, 0.018);
			}

			.radarSweep {
				position: absolute;
				width: 56%;
				aspect-ratio: 1;
				border-radius: 50%;
				background: conic-gradient(
					from 0deg,
					rgba(53, 230, 107, 0.35),
					rgba(53, 230, 107, 0.1) 22deg,
					transparent 70deg
				);
				animation: radarSpin 3.8s linear infinite;
				opacity: 0.75;
			}

			.idlePlane {
				position: relative;
				z-index: 2;
				font-size: 76px;
				filter: drop-shadow(0 18px 32px rgba(0, 0, 0, 0.45));
				animation: idleFloat 3.2s ease-in-out infinite;
			}

			.idleText {
				position: absolute;
				bottom: 18px;
				z-index: 2;
				font-size: 16px;
				color: rgba(255, 255, 255, 0.55);
				font-weight: 650;
			}

			.idleSkyPlane {
				position: absolute;
				z-index: 1;
				opacity: 0.55;
				font-size: 26px;
				filter: drop-shadow(0 8px 16px rgba(0, 0, 0, 0.45));
				animation: idlePlaneFly linear infinite;
			}

			.idleSkyPlane.p1 {
				top: 18%;
				left: -15%;
				animation-duration: 14s;
				animation-delay: 0s;
			}
			.idleSkyPlane.p2 {
				top: 55%;
				left: -20%;
				animation-duration: 19s;
				animation-delay: 4s;
				font-size: 20px;
				opacity: 0.38;
			}
			.idleSkyPlane.p3 {
				top: 34%;
				left: -25%;
				animation-duration: 23s;
				animation-delay: 8s;
				font-size: 32px;
				opacity: 0.3;
			}

			@keyframes radarSpin {
				to {
					transform: rotate(360deg);
				}
			}
			@keyframes idleFloat {
				0%,
				100% {
					transform: translateY(0) rotate(-8deg);
				}
				50% {
					transform: translateY(-9px) rotate(-2deg);
				}
			}
			@keyframes idlePlaneFly {
				0% {
					transform: translateX(0) translateY(10px) rotate(12deg);
					opacity: 0;
				}
				12% {
					opacity: 0.55;
				}
				80% {
					opacity: 0.55;
				}
				100% {
					transform: translateX(130vw) translateY(-25px) rotate(12deg);
					opacity: 0;
				}
			}

			.jf-airline-pill {
				position: absolute;
				left: 50%;
				bottom: calc(env(safe-area-inset-bottom) + 34px);
				transform: translateX(-50%);

				min-width: 220px;
				max-width: 58vw;
				height: 56px;

				border-radius: 999px;
				background: rgba(255, 255, 255, 0.96);

				display: flex;
				align-items: center;
				justify-content: center;

				z-index: 50;

				box-shadow:
					0 14px 34px rgba(0, 0, 0, 0.42),
					inset 0 1px 0 rgba(255, 255, 255, 0.95);

				backdrop-filter: blur(12px);
				-webkit-backdrop-filter: blur(12px);
			}

			.jf-airline-pill img {
				display: block;
				max-width: 50%;
				max-height: 45px;
				object-fit: contain;
			}

			.jf-airline-pill span {
				color: #111;
				font-weight: 800;
				font-size: 20px;
				line-height: 1;
			}

			.info {
				padding-top: 16px;
			}

			.mode {
				color: var(--muted);
				font-size: 21px;
				margin-bottom: 4px;
			}

			.windowInfo {
				display: inline-flex;
				align-items: center;
				gap: 6px;
				margin-top: 5px;
				margin-bottom: 8px;
				padding: 5px 10px;
				border-radius: 999px;
				background: rgba(86, 168, 255, 0.12);
				border: 1px solid rgba(86, 168, 255, 0.2);
				color: rgba(255, 255, 255, 0.72);
				font-size: 14px;
				font-weight: 700;
				white-space: nowrap;
			}

			.windowInfo.center {
				background: rgba(53, 230, 107, 0.12);
				border-color: rgba(53, 230, 107, 0.25);
				color: rgba(210, 255, 225, 0.9);
			}

			.windowInfo.side {
				background: rgba(255, 216, 77, 0.1);
				border-color: rgba(255, 216, 77, 0.22);
				color: rgba(255, 238, 160, 0.9);
			}

			.iataCallsign {
				font-size: 38px !important;
				font-weight: 850;
				letter-spacing: -0.04em;
				line-height: 0.95;
			}

			.operatorCallsign {
				margin-top: 4px;
				font-size: 17px;
				color: var(--muted);
			}

			.routeBig {
				margin-top: 6px;
				margin-bottom: 10px;
				width: 100%;
				min-width: 0;
				overflow: hidden;
			}

			.routeCities {
				display: block;
				width: 100%;
				min-width: 0;
				max-width: 100%;
				font-size: 38px !important;
				font-weight: 850;
				line-height: 0.96;
				letter-spacing: -0.055em;
				overflow: hidden;
				white-space: nowrap;
				text-overflow: ellipsis;
				word-break: normal;
				overflow-wrap: anywhere;
				text-rendering: optimizeLegibility;
			}

			.routeCodes {
				margin-top: 4px;
				color: var(--muted);
				font-size: 17px;
			}

			.airline {
				margin-top: 12px;
				font-size: 19px;
				color: var(--muted);
			}

			.aircraftCard {
				margin-top: 7px;
				display: inline-flex;
				align-items: center;
				gap: 8px;
				max-width: 100%;
				padding: 6px 10px;
				border-radius: 999px;
				background: rgba(255, 255, 255, 0.075);
				border: 1px solid rgba(255, 255, 255, 0.1);
				color: rgba(255, 255, 255, 0.72);
				font-size: 14px;
				font-weight: 700;
				white-space: nowrap;
			}

			.manufacturerLogo {
				width: 25px;
				height: 25px;
				border-radius: 50%;
				display: grid;
				place-items: center;
				font-size: 13px;
				font-weight: 900;
				background: rgba(255, 255, 255, 0.92);
				color: #111;
				border: 1px solid rgba(255, 255, 255, 0.28);
				overflow: hidden;
				flex: 0 0 auto;
			}

			.manufacturerLogo img {
				width: 82%;
				height: 82%;
				object-fit: contain;
				display: none;
			}

			.manufacturerLogoText {
				display: block;
				line-height: 1;
			}

			.aircraftSize {
				color: var(--yellow);
				font-size: 13px;
				font-weight: 800;
			}

			.reg {
				margin-top: 7px;
				font-size: 15px;
				color: var(--muted);
			}

			.special {
				margin-top: 10px;
				font-size: 17px;
				color: var(--yellow);
			}

			.special.emergency {
				color: #ff4d4d !important;
				font-weight: 900;
				text-shadow: 0 0 18px rgba(255, 77, 77, 0.55);
			}

			.metrics {
				position: absolute;
				left: 22px;
				right: 22px;
				bottom: 22px;
				display: grid;
				grid-template-columns: repeat(4, 1fr);
				gap: 8px;
			}

			.metric {
				min-height: 68px;
				border-radius: 18px;
				background: rgba(255, 255, 255, 0.08);
				border: 1px solid rgba(255, 255, 255, 0.12);
				display: flex;
				flex-direction: column;
				justify-content: center;
				align-items: center;
			}

			.metricValue {
				font-size: clamp(18px, 3vw, 30px);
				font-weight: 850;
			}

			.metricLabel {
				margin-top: 3px;
				font-size: 9px;
				letter-spacing: 0.14em;
				color: var(--muted);
			}

			.flyover {
				position: fixed;
				inset: 0;
				pointer-events: none;
				overflow: hidden;
				z-index: 9999;
				background: rgba(0, 0, 0, 0);
				transition: background 0.25s ease;
			}

			.flyover.active {
				background: rgba(0, 0, 0, 0.4);
			}

			.flyover img {
				position: absolute;
				width: 130vw;
				max-width: none;
				min-width: 900px;
				top: 50%;
				left: -150vw;
				opacity: 0;
				filter: drop-shadow(0 45px 80px rgba(0, 0, 0, 0.75));
				transform: translateY(-50%) rotate(90deg) scale(0.85);
			}

			.flyover.active img {
				animation: planeFly 3.2s ease forwards;
			}

			@keyframes planeFly {
				0% {
					left: -150vw;
					opacity: 0;
				}
				10% {
					opacity: 1;
				}
				92% {
					opacity: 1;
				}
				100% {
					left: 120vw;
					opacity: 0;
				}
			}

			.empty .iataCallsign,
			.empty .operatorCallsign,
			.empty .routeCities,
			.empty .routeCodes,
			.empty .airline,
			.empty .aircraftCard,
			.empty .reg,
			.empty .special {
				color: rgba(255, 255, 255, 0.34);
			}

			.empty .windowInfo {
				display: none;
			}

			.night {
				filter: brightness(0.72) contrast(0.92);
			}

			.night .metric {
				background: rgba(255, 255, 255, 0.05);
			}

			@media (orientation: landscape) {
				#app {
					padding: 18px;
				}

				.wall {
					width: min(1120px, 94vw);
					height: min(660px, 90vh);
					padding: 24px;
					border-radius: 34px;
				}

				.header {
					font-size: 20px;
					margin-bottom: 0;
					height: 40px;
				}

				.toggleBtn {
					padding: 6px 12px;
					font-size: 12px;
				}

				.photoWrap {
					position: absolute;
					left: 24px;
					top: 82px;
					width: 45%;
					height: 48%;
					min-height: 0;
					border-radius: 26px;
				}

				.info {
					position: absolute;
					left: 51%;
					right: 24px;
					top: 82px;
					padding-top: 0;
				}

				.mode {
					font-size: 20px;
					margin-bottom: 4px;
				}
				.windowInfo {
					font-size: 13px;
					margin-top: 4px;
					margin-bottom: 7px;
				}
				.iataCallsign {
					font-size: clamp(40px, 6vw, 72px);
				}
				.operatorCallsign {
					font-size: 17px;
				}
				.routeCities {
					font-size: clamp(28px, 4vw, 46px);
				}
				.routeCodes {
					font-size: 17px;
				}
				.airline {
					margin-top: 10px;
					font-size: 18px;
				}
				.aircraftCard {
					font-size: 13px;
					padding: 5px 9px;
				}
				.reg {
					font-size: 14px;
				}
				.special {
					margin-top: 8px;
					font-size: 16px;
				}

				.metrics {
					left: 24px;
					right: 24px;
					bottom: 22px;
					gap: 10px;
				}

				.metric {
					min-height: 70px;
					border-radius: 18px;
				}

				.metricValue {
					font-size: clamp(22px, 3.2vw, 34px);
				}
			}

			@media (max-width: 820px) {
				#app {
					padding: 14px;
				}

				.wall {
					padding: 20px;
					height: 94vh;
					border-radius: 36px;
				}

				.header {
					font-size: 22px;
					margin-bottom: 14px;
				}

				.toggleBtn {
					padding: 6px 11px;
					font-size: 12px;
				}

				.photoWrap {
					height: 30%;
					min-height: 185px;
				}

				.info {
					padding-top: 14px;
				}

				.iataCallsign {
					font-size: clamp(34px, 10vw, 54px);
				}

				.routeCities {
					font-size: clamp(22px, 8vw, 34px);
				}

				.metrics {
					left: 20px;
					right: 20px;
					bottom: 20px;
				}

				.metric {
					min-height: 64px;
				}
			}

			@media (orientation: landscape) and (max-height: 520px) {
				#app {
					padding: calc(8px + env(safe-area-inset-top)) calc(10px + env(safe-area-inset-right))
						calc(18px + env(safe-area-inset-bottom)) calc(10px + env(safe-area-inset-left));
					align-items: center;
				}

				.wall {
					width: 96vw;
					height: calc(100dvh - env(safe-area-inset-top) - env(safe-area-inset-bottom) - 20px);
					max-height: none;
					padding: 16px;
					border-radius: 26px;
				}

				.header {
					height: 34px;
					font-size: clamp(16px, 2.8vw, 22px);
					margin-bottom: 10px;
				}

				.live {
					flex: 0 0 auto;
					font-size: clamp(16px, 2.8vw, 22px);
				}

				.toggleBtn {
					flex: 0 0 auto;
					padding: 5px 9px;
					font-size: 11px;
				}

				.photoWrap {
					position: absolute;
					left: 16px;
					top: 62px;
					width: 48%;
					height: 43%;
					min-height: 0;
					border-radius: 22px;
				}

				.info {
					position: absolute;
					left: 53%;
					right: 16px;
					top: 62px;
					bottom: 100px;
					padding-top: 0;
					overflow: hidden;
				}

				.mode {
					font-size: 17px;
				}
				.windowInfo {
					font-size: 11px;
					padding: 4px 8px;
					margin-bottom: 5px;
				}
				.iataCallsign {
					font-size: clamp(30px, 5vw, 48px);
				}
				.operatorCallsign {
					font-size: 13px;
				}
				.routeCities {
					font-size: clamp(22px, 4vw, 34px);
				}
				.routeCodes {
					font-size: 13px;
				}
				.airline {
					font-size: 15px;
					margin-top: 8px;
				}
				.aircraftCard {
					font-size: 12px;
					padding: 4px 8px;
				}
				.reg {
					font-size: 12px;
				}
				.special {
					font-size: 13px;
					margin-top: 6px;
				}

				.metrics {
					left: 16px;
					right: 16px;
					bottom: 16px;
					gap: 8px;
					grid-template-columns: repeat(4, 1fr);
				}

				.metric {
					min-height: 62px;
					border-radius: 16px;
				}

				.metricValue {
					font-size: clamp(18px, 3vw, 28px);
				}

				.metricLabel {
					font-size: 8px;
				}
			}

			/* --------------------------------------------------
   JetFrame Layout Fix:
   Airline-Pille UNTER die Karte, nicht über Metriken
   Mobile kompakter / Route möglichst einzeilig
-------------------------------------------------- */

			#app {
				flex-direction: column;
				gap: 12px;
			}

			.wall {
				flex: 0 1 auto;
			}

			.jf-airline-pill {
				position: relative;
				left: auto;
				bottom: auto;
				transform: scaleX(0.72) translateY(8px);
				transform-origin: center;
				flex: 0 0 auto;

				min-width: 0;
				width: 0;
				max-width: 0;
				height: 58px;
				margin: 0 auto;

				opacity: 0;
				overflow: hidden;
				pointer-events: none;

				z-index: 10;

				transition:
					width 0.38s ease,
					max-width 0.38s ease,
					opacity 0.25s ease,
					transform 0.38s ease;
			}

			.jf-airline-pill.visible {
				width: min(360px, 62vw);
				max-width: 62vw;
				min-width: 260px;
