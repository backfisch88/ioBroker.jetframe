<!doctype html>
<html lang="de">
<head>
	<meta charset="utf-8" />
	<meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
	<title>JetFrame</title>

<link rel="apple-touch-icon" href="jetframe.png">
<link rel="icon" type="image/png" href="jetframe.png">
<meta name="apple-mobile-web-app-capable" content="yes">
<meta name="apple-mobile-web-app-status-bar-style" content="black-translucent">
<meta name="theme-color" content="#05060a">

	<style>
		:root {
			--bg: #05060a;
			--muted: rgba(255,255,255,.62);
			--green: #35e66b;
			--yellow: #ffd84d;
			--blue: #56a8ff;
		}

		* {
			box-sizing: border-box;
			-webkit-tap-highlight-color: transparent;
		}

		html,
		body {
			margin: 0;
			width: 100%;
			height: 100%;
			min-height: 100dvh;
			overflow: hidden;
			background: var(--bg);
			color: white;
			font-family: -apple-system, BlinkMacSystemFont, "SF Pro Display", "Helvetica Neue", Arial, sans-serif;
		}

		body {
			background:
				radial-gradient(circle at 18% 8%, rgba(70,110,180,.38), transparent 38%),
				radial-gradient(circle at 85% 22%, rgba(255,150,60,.18), transparent 34%),
				linear-gradient(145deg, #090b11, #020306 72%);
		}

		#app {
			width: 100vw;
			height: 100dvh;
			padding: calc(12px + env(safe-area-inset-top)) 12px calc(12px + env(safe-area-inset-bottom));
			display: flex;
			align-items: center;
			justify-content: center;
		}

		.card {
			width: min(820px, 96vw);
			height: min(1080px, 96dvh);
			border-radius: 34px;
			padding: clamp(18px, 4vw, 32px);
			background: linear-gradient(145deg, rgba(62,70,90,.58), rgba(18,18,20,.80));
			border: 1px solid rgba(255,255,255,.18);
			box-shadow:
				0 35px 100px rgba(0,0,0,.58),
				inset 0 1px 0 rgba(255,255,255,.22);
			backdrop-filter: blur(24px);
			-webkit-backdrop-filter: blur(24px);
			display: flex;
			flex-direction: column;
			gap: 18px;
			overflow: hidden;
		}

		.hero {
			flex: 1 1 auto;
			display: flex;
			flex-direction: column;
			justify-content: center;
			min-height: 0;
		}

		.logo {
			font-size: clamp(54px, 14vw, 96px);
			line-height: .9;
			margin-bottom: 14px;
		}

		h1 {
			margin: 0;
			font-size: clamp(42px, 11vw, 76px);
			line-height: .88;
			letter-spacing: -.07em;
			font-weight: 950;
		}

		.sub {
			margin-top: 14px;
			color: var(--muted);
			font-size: clamp(17px, 4vw, 28px);
			font-weight: 750;
		}

		.status {
			margin-top: 18px;
			display: inline-flex;
			width: fit-content;
			max-width: 100%;
			padding: 10px 15px;
			border-radius: 999px;
			background: rgba(53,230,107,.12);
			border: 1px solid rgba(53,230,107,.28);
			color: rgba(210,255,225,.94);
			font-size: clamp(13px, 3vw, 18px);
			font-weight: 850;
			white-space: nowrap;
			overflow: hidden;
			text-overflow: ellipsis;
		}

		.buttons {
			display: grid;
			grid-template-columns: 1fr;
			gap: 12px;
		}

		a {
			text-decoration: none;
			color: white;
		}

		.btn {
			border-radius: 26px;
			padding: 20px;
			background: rgba(255,255,255,.085);
			border: 1px solid rgba(255,255,255,.14);
			display: flex;
			align-items: center;
			justify-content: space-between;
			gap: 14px;
			box-shadow: inset 0 1px 0 rgba(255,255,255,.12);
		}

		.btn.primary {
			background: linear-gradient(145deg, rgba(86,168,255,.32), rgba(53,230,107,.20));
			border-color: rgba(86,168,255,.28);
		}

		.btn.heat {
			background: linear-gradient(145deg, rgba(255,216,77,.22), rgba(255,90,90,.14));
			border-color: rgba(255,216,77,.28);
		}

		.btnTitle {
			font-size: clamp(22px, 5vw, 34px);
			font-weight: 920;
			letter-spacing: -.035em;
		}

		.btnSub {
			margin-top: 4px;
			color: var(--muted);
			font-size: clamp(12px, 2.8vw, 16px);
			font-weight: 700;
		}

		.arrow {
			font-size: 30px;
			opacity: .76;
		}

		.stats {
			display: grid;
			grid-template-columns: repeat(3, 1fr);
			gap: 10px;
		}

		.stat {
			min-height: 74px;
			border-radius: 20px;
			background: rgba(255,255,255,.075);
			border: 1px solid rgba(255,255,255,.12);
			display: flex;
			flex-direction: column;
			align-items: center;
			justify-content: center;
		}

		.value {
			font-size: clamp(26px, 7vw, 42px);
			font-weight: 950;
			letter-spacing: -.05em;
		}

		.label {
			margin-top: 3px;
			font-size: 9px;
			letter-spacing: .14em;
			color: var(--muted);
			font-weight: 850;
		}

		.footer {
			color: rgba(255,255,255,.42);
			font-size: 12px;
			font-weight: 700;
			text-align: center;
		}

		@media (orientation: landscape) {
			#app {
				padding: 8px 12px;
			}

			.card {
				width: min(1280px, 97vw);
				height: 96dvh;
				display: grid;
				grid-template-columns: 1fr 1fr;
				grid-template-rows: 1fr auto;
				gap: 14px;
				padding: 20px;
			}

			.hero {
				grid-row: 1 / 3;
			}

			.buttons {
				align-self: end;
			}

			.stats {
				align-self: end;
			}

			.footer {
				display: none;
			}
		}
	</style>
</head>
<body>
	<div id="app">
		<div class="card">
			<div class="hero">
				<div class="logo">✈️</div>
				<h1>JetFrame</h1>
				<div class="sub">Dein Live-Flugradar für Zuhause</div>
				<div id="statusText" class="status">Verbinde mit JetFrame…</div>
			</div>

			<div class="buttons">
				<a id="frameLink" href="frame.html">
					<div class="btn primary">
						<div>
							<div class="btnTitle">Live Frame</div>
							<div class="btnSub">Aktuelles Flugzeug anzeigen</div>
						</div>
						<div class="arrow">›</div>
					</div>
				</a>

				<a id="heatmapLink" href="heatmap.html">
					<div class="btn heat">
						<div>
							<div class="btnTitle">Heatmap</div>
							<div class="btnSub">Tagesstatistik & beste Spotterzeit</div>
						</div>
						<div class="arrow">›</div>
					</div>
				</a>
			</div>

			<div class="stats">
				<div class="stat">
					<div id="totalFlights" class="value">–</div>
					<div class="label">HEUTE</div>
				</div>
				<div class="stat">
					<div id="currentHour" class="value">–</div>
					<div class="label">AKTUELL</div>
				</div>
				<div class="stat">
					<div id="landings" class="value">–</div>
					<div class="label">LANDUNGEN</div>
				</div>
			</div>

			<div class="footer">JetFrame · Auto-Refresh alle 10 Sekunden</div>
		</div>
	</div>

	<script>
		let API_BASE = (() => {
			const proto = window.location.protocol || 'http:';
			const host = window.location.hostname || '127.0.0.1';
			const url = new URL(window.location.href);
			const apiHost = url.searchParams.get('apiHost') || host;
			const apiPort = url.searchParams.get('apiPort') || '8087';
			return proto + '//' + apiHost + ':' + apiPort;
		})();

		const DP_ROOT = (() => {
			const url = new URL(window.location.href);
			const instance = url.searchParams.get('instance') || '0';
			return 'jetframe.' + String(instance).replace(/[^0-9]/g, '');
		})();

		function $(id) {
			return document.getElementById(id);
		}

		function clean(v) {
			if (v === null || v === undefined) return '';
			v = String(v).trim();
			if (v === 'null' || v === 'undefined') return '';
			if ((v.startsWith('"') && v.endsWith('"')) || (v.startsWith("'") && v.endsWith("'"))) {
				v = v.slice(1, -1);
			}
			return v.replace(/\\"/g, '"').replace(/\\n/g, '\n').trim();
		}

		async function readState(id) {
			try {
				const res = await fetch(API_BASE + '/getPlainValue/' + encodeURIComponent(id), {
					cache: 'no-store',
				});
				if (!res.ok) return '';
				return clean(await res.text());
			} catch {
				return '';
			}
		}

		function applyQueryLinks() {
			const q = window.location.search || '';
			$('frameLink').href = 'frame.html' + q;
			$('heatmapLink').href = 'heatmap.html' + q;
		}

		async function poll() {
			const base = DP_ROOT + '.statistics.today';

			const [
				status,
				total,
				current,
				landings,
				runway,
			] = await Promise.all([
				readState(DP_ROOT + '.status'),
				readState(base + '.totalFlights'),
				readState(base + '.currentHourFlights'),
				readState(base + '.landings'),
				readState(DP_ROOT + '.idleRunwayText'),
			]);

			$('totalFlights').textContent = Number(total || 0);
			$('currentHour').textContent = Number(current || 0);
			$('landings').textContent = Number(landings || 0);

			const parts = [];
			if (status) parts.push('Status: ' + status);
			if (runway) parts.push(runway);

			$('statusText').textContent = parts.length ? parts.join(' · ') : 'JetFrame bereit';
		}

		applyQueryLinks();
		poll();
		setInterval(poll, 10000);
	</script>
</body>
</html>
