{
	"name": "iobroker.jetframe",
	"version": "0.4.0",
	"description": "Flight tracking and visualization for window-based aircraft detection",
	"author": {
		"name": "backfisch88",
		"email": "h@h.de"
	},
	"contributors": [
		{
			"name": "backfisch"
		}
	],
	"homepage": "https://github.com/backfisch88/ioBroker.jetframe",
	"license": "MIT",
	"keywords": [
		"flight",
		"adsb",
		"aircraft",
		"tracking",
		"fr24"
	],
	"repository": {
		"type": "git",
		"url": "https://github.com/backfisch88/ioBroker.jetframe.git"
	},
	"engines": {
		"node": ">= 22"
	},
	"dependencies": {
		"@iobroker/adapter-core": "^3.3.2"
	},
	"devDependencies": {
		"@alcalzone/release-script": "^5.1.1",
		"@alcalzone/release-script-plugin-iobroker": "^5.1.2",
		"@alcalzone/release-script-plugin-license": "^5.1.1",
		"@alcalzone/release-script-plugin-manual-review": "^5.1.1",
		"@iobroker/adapter-dev": "^1.5.0",
		"@iobroker/dev-server": "^0.8.0",
		"@iobroker/eslint-config": "^2.2.0",
		"@iobroker/testing": "^5.2.2",
		"@tsconfig/node22": "^22.0.5",
		"@types/iobroker": "npm:@iobroker/types@^7.1.1",
		"@types/node": "^22.19.17",
		"prettier": "^3.8.3",
		"rimraf": "^6.1.3",
		"source-map-support": "^0.5.21",
		"ts-node": "^10.9.2",
		"typescript": "~5.9.3"
	},
	"main": "build/main.js",
	"files": [
		"admin/",
		"build/",
		"www/",
		"io-package.json",
		"package.json",
		"README.md",
		"LICENSE"
	],
	"scripts": {
		"prebuild": "rimraf build",
		"build": "build-adapter ts",
		"watch": "build-adapter ts --watch",
		"prebuild:ts": "rimraf build",
		"build:ts": "build-adapter ts",
		"watch:ts": "build-adapter ts --watch",
		"test:ts": "mocha --config test/mocharc.custom.json src/**/*.test.ts",
		"test:package": "mocha test/package --exit",
		"test:integration": "mocha test/integration --exit",
		"test": "npm run test:ts && npm run test:package",
		"check": "tsc --noEmit",
		"lint": "eslint -c eslint.config.mjs .",
		"translate": "translate-adapter",
		"release": "release-script",
		"dev-server": "dev-server"
	},
	"bugs": {
		"url": "https://github.com/backfisch88/ioBroker.jetframe/issues"
	},
	"readmeFilename": "README.md"
}
